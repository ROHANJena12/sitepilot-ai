# =============================================================================
# SitePilot AI — .gitignore
# Covers Next.js, FastAPI, Python, Node, pnpm, editors, Docker, and OS noise.
# =============================================================================

# ----- Environment & secrets -----
.env
.env.*
!.env.example
*.pem
*.key
secrets/
credentials/

# ----- Dependencies -----
node_modules/
.pnpm-store/
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ----- Build / output -----
dist/
build/
out/
.next/
.turbo/
.vercel/
*.tsbuildinfo
.cache/
coverage/
*.egg-info/
.eggs/
*.egg

# ----- Python / FastAPI -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.nox/
*.manifest
*.spec

# ----- Testing & tooling -----
.nyc_output/
*.lcov
.jest/
playwright-report/
test-results/

# ----- Editors / IDEs -----
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
.cursor/*
!.cursor/rules/
!.cursor/skills/

# ----- OS -----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
*~

# ----- Docker -----
*.log
docker-compose.override.yml

# ----- Misc -----
*.local
tmp/
temp/
.temp/
logs/*
!logs/.gitkeep
.pids/*
!.pids/.gitkeep
*.pid
*.seed
.serverless/
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl
