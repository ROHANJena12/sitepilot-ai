# SitePilot AI — environment variable template
# Copy to .env and fill in values. Never commit real secrets.

# AI providers
# Default: Gemini for all AI features. Fallback: OpenRouter → OpenAI.
AI_DEFAULT_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENAI_API_KEY=


# External integrations
GOOGLE_PAGESPEED_API_KEY=

# Data stores
DATABASE_URL=postgresql+asyncpg://sitepilot:sitepilot@localhost:5434/sitepilot
REDIS_URL=redis://localhost:6379/0

# Application secrets (required — strong unique value in production)
SECRET_KEY=change-me-in-production

# Public web URL for report share links
PUBLIC_WEB_URL=http://localhost:3000

# API
APP_NAME=sitepilot-api
APP_VERSION=0.1.0
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Security / rate limits (see docs/DEPLOYMENT.md)
SECURITY_HEADERS_ENABLED=true
RATE_LIMIT_ENABLED=true

# Frontend public config
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
