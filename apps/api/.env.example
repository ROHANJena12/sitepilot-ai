# SitePilot AI API — local environment template
# Copy to apps/api/.env (never commit secrets).

APP_NAME=sitepilot-api
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Async PostgreSQL (SQLAlchemy + asyncpg)
DATABASE_URL=postgresql+asyncpg://sitepilot:sitepilot@localhost:5434/sitepilot

# Optional — used by Redis queue backend / readiness
REDIS_URL=redis://localhost:6379/0

# AI job queue (Sprint 27)
# inmemory = local BackgroundTasks (default; no Redis required)
# redis = distributed workers via `python -m app.ai.jobs.worker_main`
AI_QUEUE_BACKEND=inmemory
QUEUE_NAME=sitepilot:ai:jobs
VISIBILITY_TIMEOUT=60
WORKER_POLL_INTERVAL=0.5
MAX_CONCURRENT_WORKERS=1

# OpenAI (optional — final fallback)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Gemini (default provider — Sprint 30.6)
AI_DEFAULT_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# OpenRouter (fallback when Gemini is unavailable)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-oss-120b:free
# Optional override via AI_ prefix:
# AI_OPENROUTER_MODEL=openai/gpt-oss-120b:free

# Comma-separated origins for CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

SECRET_KEY=change-me-in-production

# Public web origin for share links (Sprint 31)
PUBLIC_WEB_URL=http://localhost:3000
# SHARE_TOKEN_TTL_SECONDS=604800

# Security headers (Sprint 35) — see docs/DEPLOYMENT.md
SECURITY_HEADERS_ENABLED=true
# SECURITY_ENABLE_HSTS=false
# SECURITY_CSP=default-src 'none'; frame-ancestors 'none'; base-uri 'none'
# SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
# SECURITY_X_FRAME_OPTIONS=DENY
# SECURITY_PERMISSIONS_POLICY=camera=(), microphone=(), geolocation=()

# Rate limiting (Sprint 35)
RATE_LIMIT_ENABLED=true
# RATE_LIMIT_AUDITS_LIMIT=5
# RATE_LIMIT_AUDITS_WINDOW_SECONDS=600
# RATE_LIMIT_AI_LIMIT=30
# RATE_LIMIT_AI_WINDOW_SECONDS=60
# RATE_LIMIT_SHARE_LIMIT=20
# RATE_LIMIT_SHARE_WINDOW_SECONDS=600

# Readiness — require Redis on GET /ready (also implied by AI_QUEUE_BACKEND=redis)
# READY_REQUIRE_REDIS=false
